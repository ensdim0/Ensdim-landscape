# Repository-level ignores

# Node / JS
node_modules/

# Python
.venv/

# Flutter / Dart
**/build/
.dart_tool/

# Environment files
.env
.env.*
!.env.example
!**/.env.example
!/dashboard/.env

# Supabase local keys (remove if present)
/supabase keys.txt
!/key.md

# Supabase CLI temporary files
dashboard/supabase/.temp/

# Private keys
*.pem
*.key

# IDEs
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
