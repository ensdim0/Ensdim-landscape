# Dashboard environment example
# Copy to `.env` (do NOT commit `.env` to source control).
# Provide only the public/anonymous Supabase key here. Never store
# the Supabase SERVICE_ROLE key in client-side environment files.

# Your Supabase project URL (example: https://xyzabc.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase ANON key (public, used by the client). Keep secret when possible.
VITE_SUPABASE_ANON_KEY=

# Application environment: development | staging | production
VITE_APP_ENV=development
